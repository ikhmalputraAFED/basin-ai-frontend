# --- Phase 1 (standalone) -----------------------------------------------------
# Where the FSM Assistant container lives. The Nitro proxy at /api/basin-ai
# forwards browser requests here so we don't hit CORS.
BASIN_AI_UPSTREAM_URL=https://ca-basinai-fsm-api-dev.grayriver-cc62666b.southeastasia.azurecontainerapps.io

# Browser-facing base URL — keep on the same origin to use the Nitro proxy.
NUXT_PUBLIC_BASIN_AI_API_BASE=/api/basin-ai

# Dev-only auth bypass. Lets you open the chat without going through Seek.
# Active only when `import.meta.dev` is true; ignored in production builds.
NUXT_PUBLIC_AUTH_BYPASS=true

# Dev-only identity forwarded as `X-User-Id` to the FSM API while the bypass
# is on. Set to a real Keycloak user id (or test id the FSM API accepts).
NUXT_PUBLIC_DEV_USER_ID=
NUXT_PUBLIC_DEV_USERNAME=

# --- Phase 2 (linked to Seek) -------------------------------------------------
# Used by the auth middleware to redirect to Seek's login and to refresh tokens.
NUXT_PUBLIC_SEEK_APP_URL=http://localhost:3000
NUXT_PUBLIC_SEEK_API_BASE=http://localhost:8081/api/v1
